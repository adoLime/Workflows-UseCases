    <bpmn:sequenceFlow id="Flow_1e07e90" sourceRef="Task_6ad8ab0e-d098-468b-931a-d74b76941b09_gateway_3" targetRef="Task_6ad8ab0e-d098-468b-931a-d74b76941b09_poll_job_res" />
    <bpmn:sequenceFlow id="Flow_8f8460e" sourceRef="Task_6ad8ab0e-d098-468b-931a-d74b76941b09_poll_job_res" targetRef="Task_6ad8ab0e-d098-468b-931a-d74b76941b09_gateway_4" />
