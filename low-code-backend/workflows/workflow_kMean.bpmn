      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusJob == "FINISHED" || statusJob == "SUCCESS"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ff862b7" sourceRef="Task_6ad8ab0e-d098-468b-931a-d74b76941b09_set_vars_2" targetRef="Task_6ad8ab0e-d098-468b-931a-d74b76941b09_human" />
    <bpmn:sequenceFlow id="Flow_8414c3c" sourceRef="Task_6ad8ab0e-d098-468b-931a-d74b76941b09_gateway_4" targetRef="Task_6ad8ab0e-d098-468b-931a-d74b76941b09_analyze_failed_job">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusJob == "ERROR" || statusJob == "FAILURE"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_8416f6d" sourceRef="Task_6ad8ab0e-d098-468b-931a-d74b76941b09_analyze_failed_job" targetRef="Task_6ad8ab0e-d098-468b-931a-d74b76941b09_alt_end_2" />
    <bpmn:sequenceFlow id="Flow_b451b56" sourceRef="Task_6ad8ab0e-d098-468b-931a-d74b76941b09_gateway_4" targetRef="Task_6ad8ab0e-d098-468b-931a-d74b76941b09_gateway_3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusJob != "ERROR" &amp;&amp; statusJob != "FINISHED" &amp;&amp; statusJob != "FAILURE" &amp;&amp; statusJob != "SUCCESS"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_820b647" sourceRef="Task_6ad8ab0e-d098-468b-931a-d74b76941b09_human" targetRef="EndEvent_1" />
    </bpmn:process>
