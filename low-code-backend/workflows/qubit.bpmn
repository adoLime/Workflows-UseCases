    <bpmn:scriptTask id="Task_quantum_group_0_set_circuit" name="Set Circuit" scriptFormat="groovy" camunda:asyncAfter="true" camunda:exclusive="true" camunda:resultVariable="circuit">
      <bpmn:incoming>Flow_48e4a3c</bpmn:incoming>
      <bpmn:outgoing>Flow_ccee38c</bpmn:outgoing>
      <bpmn:script>execution.setVariable("circuit", """OPENQASM 3.1;
include "stdgates.inc";
qubit[1] leqo_reg;
/* Start node 6ff749c3-d888-4618-b75b-481773d905e3 */
let leqo_2987cea61107534fb3982fef5b8a954f_literal = leqo_reg[{0}];
@leqo.output 0
let leqo_2987cea61107534fb3982fef5b8a954f_out = leqo_2987cea61107534fb3982fef5b8a954f_literal;
/* End node 6ff749c3-d888-4618-b75b-481773d905e3 */
/* Start node e89600f0-39c5-4dc9-83f3-e613a935cd73 */
@leqo.input 0
let leqo_080fde97198d56e7911f8cc5c4b07dbf_q0 = leqo_reg[{0}];
h leqo_080fde97198d56e7911f8cc5c4b07dbf_q0;
@leqo.output 0
let leqo_080fde97198d56e7911f8cc5c4b07dbf_q0_out = leqo_080fde97198d56e7911f8cc5c4b07dbf_q0;
/* End node e89600f0-39c5-4dc9-83f3-e613a935cd73 */
/* Start node 64a3879a-90cc-4ecb-b071-2da5f244a6e6 */
@leqo.input 0
let leqo_d325ddf9dcbf55c894e0f35835a709ba_q = leqo_reg[{0}];
bit[1] leqo_d325ddf9dcbf55c894e0f35835a709ba_result = measure leqo_d325ddf9dcbf55c894e0f35835a709ba_q[{0}];
@leqo.output 0
let leqo_d325ddf9dcbf55c894e0f35835a709ba_out = leqo_d325ddf9dcbf55c894e0f35835a709ba_result;
@leqo.output 1
let leqo_d325ddf9dcbf55c894e0f35835a709ba_qubit_out = leqo_d325ddf9dcbf55c894e0f35835a709ba_q;
/* End node 64a3879a-90cc-4ecb-b071-2da5f244a6e6 */
""")</bpmn:script>
      </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_48e4a3c" sourceRef="StartEvent_1" targetRef="Task_quantum_group_0_set_circuit" />
