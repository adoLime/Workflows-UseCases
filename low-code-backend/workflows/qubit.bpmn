      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusJob == "FINISHED" || statusJob == "SUCCESS"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_508bfd8" sourceRef="Task_quantum_group_0_set_vars_2" targetRef="Task_quantum_group_0_human" />
    <bpmn:sequenceFlow id="Flow_03848ab" sourceRef="Task_quantum_group_0_gateway_4" targetRef="Task_quantum_group_0_analyze_failed_job">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusJob == "ERROR" || statusJob == "FAILURE"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_33d73e0" sourceRef="Task_quantum_group_0_analyze_failed_job" targetRef="Task_quantum_group_0_alt_end_2" />
    <bpmn:sequenceFlow id="Flow_2391ac3" sourceRef="Task_quantum_group_0_gateway_4" targetRef="Task_quantum_group_0_gateway_3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${statusJob != "ERROR" &amp;&amp; statusJob != "FINISHED" &amp;&amp; statusJob != "FAILURE" &amp;&amp; statusJob != "SUCCESS"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_b371800" sourceRef="Task_quantum_group_0_human" targetRef="EndEvent_1" />
    </bpmn:process>
